{
  "manifest_version": 3,
  "name": "FluentFlow — Bilingual Reading & Learning",
  "version": "0.4.2",
  "description": "Read any English page bilingually, look up words, learn from video subtitles, and build your vocabulary — private by default.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FluentFlow"
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://www.youtube-nocookie.com/*"
      ],
      "js": ["pagehook.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "permissions": ["activeTab", "storage", "unlimitedStorage", "contextMenus", "sidePanel"],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*",
    "https://api.openai.com/*",
    "https://api.cognitive.microsofttranslator.com/*",
    "https://api.anthropic.com/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "commands": {
    "toggle-translation": {
      "suggested_key": { "default": "Alt+T" },
      "description": "沉浸翻译（翻译 / 还原整页）"
    },
    "open-quick-translate": {
      "suggested_key": { "default": "Alt+D" },
      "description": "快捷翻译（打开翻译窗口）"
    },
    "toggle-subtitle": {
      "suggested_key": { "default": "Alt+C" },
      "description": "双语字幕面板（视频页）"
    },
    "cycle-display-mode": {
      "suggested_key": { "default": "Alt+M" },
      "description": "切换显示模式（双语 / 仅译文 / 仅原文）"
    },
    "translate-selection": {
      "description": "翻译选中文本"
    },
    "open-side-panel": {
      "description": "打开学习面板（生词本 · 句子本 · AI）"
    }
  }
}
